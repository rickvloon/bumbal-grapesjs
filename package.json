{
  "name": "bumbal-grapesjs",
  "version": "1.0.33",
  "description": "GrapesJS preset configuration for the newsletter editor",
  "main": "dist/index.js",
  "style": "dist/index.css",
  "files": [
    "dist/"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rickvloon/bumbal-grapesjs"
  },
  "scripts": {
    "v:patch": "npm version --no-git-tag-version patch",
    "start": "grapesjs-cli serve",
    "build": "grapesjs-cli build",
    "prepare": "npm run build",
    "test": "jest"
  },
  "keywords": [
    "grapesjs",
    "plugin",
    "newsletter",
    "preset"
  ],
  "author": "Artur Arseniev",
  "license": "BSD-3-Clause",
  "devDependencies": {
    "@babel/preset-typescript": "^7.18.6",
    "@types/jest": "^29.4.0",
    "css-loader": "^7.1.4",
    "grapesjs": "^0.21.2",
    "grapesjs-cli": "^4.1.1",
    "jest": "^29.4.1",
    "juice": "^8.1.0",
    "mini-css-extract-plugin": "^2.10.2"
  },
  "babel": {
    "env": {
      "test": {
        "presets": [
          "@babel/preset-env",
          "@babel/preset-typescript"
        ]
      }
    }
  },
  "jest": {
    "modulePaths": [
      "./src"
    ]
  },
  "dependencies": {
    "i18next": "^23.16.8",
    "twig": "^3.0.0"
  }
}
